# ── Application ───────────────────────────────────────────────────────────────
# Allowed values: local-dev | dev | staging | prod | test
BACKEND_ENV=local-dev

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DATABASE=appdb
# disable | require | verify-full
POSTGRES_SSLMODE=disable

# Connection pool tuning (optional — defaults shown)
# DB_MAX_OPEN_CONNS=10
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=300

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Set to true for TLS (e.g. AWS ElastiCache Serverless)
REDIS_TLS_ENABLED=false

# ── Swagger docs (optional) ───────────────────────────────────────────────────
# SWAGGER_DOCS_BASE_URL=localhost:3000
